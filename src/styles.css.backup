@import "tailwindcss";

@theme {
  --color-primary: #0f172a;
  --color-secondary: #1e293b;
  --color-accent: #3b82f6;
  --color-accent-light: #60a5fa;
  --color-success: #10b981;
  --color-warning: #f59e0b;
  --color-error: #ef4444;
  
  --font-sans: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* Cinematic Color Palette (CSS Variables for components) */
:root {
  --primary: #0f172a;
  --secondary: #1e293b;
  --accent: #3b82f6;
  --accent-light: #60a5fa;
  --success: #10b981;
  --warning: #f59e0b;
  --error: #ef4444;
  --text-primary: #f1f5f9;
  --text-secondary: #cbd5e1;
  --border: #334155;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: linear-gradient(135deg, #0f172a 0%, #1a1f35 50%, #0f172a 100%);
  background-attachment: fixed;
  color: var(--text-primary);
  min-height: 100vh;
}

/* Cinematic Scrollbar */
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  background: var(--primary);
}

::-webkit-scrollbar-thumb {
  background: var(--accent);
  border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent-light);
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

/* Cinematic Cards */
.card {
  @apply bg-gradient-to-br from-slate-800 to-slate-900 rounded-xl border border-slate-700 shadow-2xl;
  backdrop-filter: blur(10px);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:hover {
  @apply border-blue-500 shadow-2xl;
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(59, 130, 246, 0.2);
}

/* Cinematic Buttons */
.btn {
  @apply px-6 py-3 rounded-lg font-semibold transition-all duration-300;
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.1);
  transition: left 0.3s ease;
  z-index: -1;
}

.btn:hover::before {
  left: 100%;
}

.btn-primary {
  @apply bg-gradient-to-r from-blue-600 to-blue-500 text-white shadow-lg;
}

.btn-primary:hover {
  @apply shadow-2xl;
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.5);
}

.btn-secondary {
  @apply bg-slate-700 text-white border border-slate-600;
}

.btn-secondary:hover {
  @apply bg-slate-600 border-blue-500;
}

/* Cinematic Inputs */
.input {
  @apply bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 text-white placeholder-slate-400;
  transition: all 0.3s ease;
}

.input:focus {
  @apply outline-none border-blue-500 bg-slate-700;
  box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
}

/* Cinematic Gradients */
.gradient-text {
  background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gradient-border {
  position: relative;
  border: 2px solid transparent;
  background-image: linear-gradient(var(--primary), var(--primary)), 
                    linear-gradient(135deg, #3b82f6, #60a5fa);
  background-origin: border-box;
  background-clip: padding-box, border-box;
}

/* Cinematic Shadows */
.shadow-glow {
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.3);
}

.shadow-glow-lg {
  box-shadow: 0 0 50px rgba(59, 130, 246, 0.4);
}

/* Cinematic Animations */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
  }
  50% {
    box-shadow: 0 0 40px rgba(59, 130, 246, 0.6);
  }
}

@keyframes shimmer {
  0% {
    background-position: -1000px 0;
  }
  100% {
    background-position: 1000px 0;
  }
}

.animate-fadeInUp {
  animation: fadeInUp 0.6s ease-out;
}

.animate-slideInLeft {
  animation: slideInLeft 0.6s ease-out;
}

.animate-slideInRight {
  animation: slideInRight 0.6s ease-out;
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

/* Cinematic Text */
.text-glow {
  text-shadow: 0 0 20px rgba(59, 130, 246, 0.5);
}

.text-glow-lg {
  text-shadow: 0 0 30px rgba(59, 130, 246, 0.7);
}

/* Cinematic Backdrop */
.backdrop-blur-xl {
  backdrop-filter: blur(20px);
}

/* Smooth Transitions */
* {
  transition: color 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
}

/* Enhanced Cinematic Effects */
.glass-effect {
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(59, 130, 246, 0.2);
}

.glass-effect:hover {
  background: rgba(15, 23, 42, 0.8);
  border-color: rgba(59, 130, 246, 0.4);
}

/* Cinematic Hover Effects */
.hover-lift {
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.hover-lift:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 50px rgba(59, 130, 246, 0.3);
}

/* Cinematic Borders */
.border-glow {
  border: 2px solid rgba(59, 130, 246, 0.3);
  box-shadow: inset 0 0 20px rgba(59, 130, 246, 0.1);
}

.border-glow:hover {
  border-color: rgba(59, 130, 246, 0.6);
  box-shadow: inset 0 0 20px rgba(59, 130, 246, 0.2), 0 0 30px rgba(59, 130, 246, 0.2);
}

/* Cinematic Loading */
@keyframes cinematic-load {
  0% {
    background-position: -1000px 0;
    opacity: 0.5;
  }
  50% {
    opacity: 1;
  }
  100% {
    background-position: 1000px 0;
    opacity: 0.5;
  }
}

.cinematic-loading {
  background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.3), transparent);
  background-size: 1000px 100%;
  animation: cinematic-load 2s infinite;
}

/* Cinematic Overlay */
.overlay-dark {
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.8) 0%, rgba(30, 41, 59, 0.6) 100%);
}

/* Cinematic Text Effects */
.text-cinematic {
  font-weight: 600;
  letter-spacing: 0.5px;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
}

/* Cinematic Divider */
.divider-glow {
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.5), transparent);
  box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
}

/* Cinematic Focus States */
.focus-glow:focus {
  outline: none;
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.5), inset 0 0 20px rgba(59, 130, 246, 0.1);
}

/* Cinematic Transitions for Lists */
.list-item {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.list-item:hover {
  transform: translateX(4px);
  background: rgba(59, 130, 246, 0.1);
  border-left: 3px solid rgba(59, 130, 246, 0.6);
  padding-left: calc(1rem - 3px);
}

/* Cinematic Badges */
.badge-cinematic {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(96, 165, 250, 0.1));
  border: 1px solid rgba(59, 130, 246, 0.4);
  box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
}

/* Cinematic Progress Bar */
.progress-bar-cinematic {
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.3), rgba(96, 165, 250, 0.5));
  box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
  border-radius: 10px;
  overflow: hidden;
}

.progress-bar-cinematic::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  right: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shimmer 2s infinite;
}

/* Cinematic Transitions for Forms */
.form-group {
  transition: all 0.3s ease;
}

.form-group:focus-within {
  transform: scale(1.02);
}

/* Cinematic Success/Error States */
.state-success {
  border-color: rgba(16, 185, 129, 0.5);
  box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
}

.state-error {
  border-color: rgba(239, 68, 68, 0.5);
  box-shadow: 0 0 20px rgba(239, 68, 68, 0.2);
}

.state-warning {
  border-color: rgba(245, 158, 11, 0.5);
  box-shadow: 0 0 20px rgba(245, 158, 11, 0.2);
}
